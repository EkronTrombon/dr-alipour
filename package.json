{
  "name": "dr-alipour-theme",
  "version": "1.0.0",
  "description": "Dr. Alipour Psychology & Coaching Website - WordPress Theme",
  "main": "index.js",
  "scripts": {
    "dev": "tailwindcss -i ./theme/assets/css/input.css -o ./theme/assets/css/style.css --watch",
